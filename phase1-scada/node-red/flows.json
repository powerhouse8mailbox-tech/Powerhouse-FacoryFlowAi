                "modbus-read"
            ]
        ]
    },
    {
        "id": "format-data",
        "type": "function",
        "z": "f1",
        "name": "Format JSON",
        "func": "const data = msg.payload;\n\n// Modbus registers:\n// 0: Status (0=stopped, 1=running)\n// 1: Temperature (x10)\n// 2: Cycle Time\n// 3: Production Count\n\nconst statusMap = {0: \"stopped\", 1: \"running\"};\n\nmsg.payload = {\n    \"machine_id\": \"LINE_01\",\n    \"status\": statusMap[data[0]] || \"unknown\",\n    \"temperature\": data[1] / 10.0,\n    \"cycle_time\": data[2],\n    \"production_count\": data[3]\n};\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 120,
        "wires": [
            [
                "http-post",
                "debug-out",
                "dash-status",
                "dash-temp",
                "dash-count"
            ]
        ]
    },
    {
        "id": "http-post",
        "type": "http request",
        "z": "f1",
        "name": "Send to API",
        "method": "POST",
