                "format-data"
            ]
        ]
    },
    {
        "id": "trigger",
        "type": "inject",
        "z": "f1",
        "name": "Poll every 2s",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "2",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
